# ─────────────────────────────────────────────────────────────
# Relay server (set these in Coolify → Environment Variables)
# ─────────────────────────────────────────────────────────────
PORT=3000

# REQUIRED — long random secret shared by relay, agent, and browser
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_TOKEN=change-this-to-a-long-random-secret

# ─────────────────────────────────────────────────────────────
# PC Agent (set these before running agent.js or in pc-app/.env)
# ─────────────────────────────────────────────────────────────

# Full WSS URL to the relay (from Coolify deployment)
RELAY_URL=wss://your-relay-url.148.230.100.16.sslip.io

# Same token as relay
# AGENT_TOKEN=change-this-to-a-long-random-secret

# Shell to launch (default: powershell.exe on Windows)
SHELL=powershell.exe

# Initial terminal dimensions (optional)
COLS=200
ROWS=50
